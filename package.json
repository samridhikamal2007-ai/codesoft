{
    "name": "rightplace",
    "version": "1.0.0",
    "description": "RightPlace - Professional Job Portal Application",
    "scripts": {
        "install:all": "npm install && cd server && npm install && cd ../client && npm install",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "server": "cd server && npm run dev",
        "client": "cd client && npm start",
        "build": "cd client && npm run build",
        "seed": "cd server && node seeder.js -i",
        "reset": "npm run seed && npm run dev"
    },
    "keywords": [
        "job-portal",
        "mern",
        "react",
        "nodejs",
        "mongodb"
    ],
    "author": "RightPlace Team",
    "license": "MIT",
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}